// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String?
  email     String?  // Added for V2
  role      String   @default("USER") // ADMIN, USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  transactions Transaction[]
  orders       Order[]
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  size          String?
  price         Float
  oldPrice      Float?   // Retains original price when a discount is applied
  sku           String   @unique // Barcode
  kaspiSku      String?  // SKU specific to Kaspi
  kaspiUrl      String?  // Direct link to product page on Kaspi
  halykUrl      String?  // Direct link to product page on Halyk Market
  image         String?  // Base64 or URL
  quantity      Int      @default(0)
  quantityShowroom Int   @default(0) // Showroom stock
  preOrderDays  Int?     // If set, Kaspi shows this as pre-order with N days lead time
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  storefrontProductId Int?
  storefrontProduct   StorefrontProduct? @relation(fields: [storefrontProductId], references: [id])

  // Relations
  transactions Transaction[]
  orderItems   OrderItem[]
}

model StorefrontProduct {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?   // Optional description
  image         String?   // Main image (legacy fallback)
  images        String[]  @default([]) // Up to 5 images
  video         String?   // Instagram video link
  isActive      Boolean   @default(true) // Whether to display on storefront
  discountPrice Float?    // Promotional exact price. If set, this overrides product variant prices for display
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products    Product[] // Relations to actual variants/sizes
}


model Transaction {
  id        Int      @id @default(autoincrement())
  type      String   // IN, OUT, ADJUSTMENT
  quantity  Int
  date      DateTime @default(now())
  
  // Relations
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}

model SiteContent {
  id          Int      @id @default(1)
  text_ru     String?  @db.Text
  text_kz     String?  @db.Text
  photo1      String?
  photo2      String?
  video_url   String?
  video2_url  String?
  video3_url  String?
  returns_ru  String?  @db.Text
  returns_kz  String?  @db.Text
  contacts_ru String?  @db.Text
  contacts_kz String?  @db.Text
  updatedAt   DateTime @default(now()) @updatedAt
}

model Order {
  id             Int      @id @default(autoincrement())
  orderNumber    String   @unique
  clientName     String?
  clientPhone    String?
  shippingMethod String?  // Legacy field, mapped to deliveryMethod if needed
  deliveryMethod String   @default("PICKUP") // CDEK, ALMATY_COURIER, RIKA, POST, YANDEX, KASPI, PICKUP
  
  // Customer Details
  address        String? // Full string (legacy or computed)
  city           String?
  
  // Structured Address (New)
  street         String?
  house          String?
  apartment      String?
  postalCode     String? // For Kazpost
  comment        String? // Courier comment

  trackingNumber String?
  waybillUuid    String?
  
  // Payment Details
  paymentMethod  String   @default("CASH") // CASH, CARD, TRANSFER, KASPI, COD (Cash on Delivery)
  codAmount      Float?   // Amount for Cash on Delivery (CDEK)

  status         String   @default("PENDING") // PENDING, PROCESSING, SENT, DELIVERED, COMPLETED, CANCELLED
  totalAmount    Float
  source         String   @default("POS") // POS, WEBSITE, KASPI
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  items          OrderItem[]
  history        OrderHistory[]
  userId         Int?     // For admin created orders
  user           User?    @relation(fields: [userId], references: [id])
  
  customerId     String?  // For storefront users
  customer       Customer? @relation(fields: [customerId], references: [id])
  returns        ReturnRequest[]

  // Delivery & Fees
  deliveryCost   Float?   @default(0)
  cdekPvzCode    String?  // Code for the pickup point selected by customer
  paymentStatus  String   @default("PENDING") // PENDING, PAID, FAILED (for kaspi/halyk invoices)
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  
  productId Int?
  product   Product? @relation(fields: [productId], references: [id])

  // Snapshot data
  name      String
  sku       String
  size      String?
  image     String? // Snapshot or custom image
  quantity  Int
  price     Float
  requiresTransfer Boolean @default(false) // If true, this item was picked from Showroom and needs transfer
}

model OrderHistory {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  action    String   // CREATED, UPDATED, STATUS_CHANGE, SENT_TO_CDEK
  details   String?  // Description of change
  createdAt DateTime @default(now())
}

model Balance {
  id        Int      @id @default(1)
  amount    Float    @default(0)
  updatedAt DateTime
}

model Credit {
  id             Int      @id @default(autoincrement())
  name           String
  principal      Float
  dailyPayment   Float
  monthlyPayment Float
  startDate      DateTime
  durationMonths Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Customer {
  id              String   @id @default(cuid())
  phone           String   @unique
  email           String?  @unique
  password        String
  firstName       String?
  lastName        String?
  address         String?  // Default saved address
  discountPercent Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  orders          Order[]
  returns         ReturnRequest[]
}

model ReturnRequest {
  id              String   @id @default(cuid())
  orderId         Int
  order           Order    @relation(fields: [orderId], references: [id])
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  reason          String?
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  items           Json     // Which items and quantities are being returned
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
